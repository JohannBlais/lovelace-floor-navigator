# Copie ce fichier en `.env.local` (gitignored) et adapte la valeur ci-dessous.
#
# HA_LOCAL_DIR pointe vers le dossier `www/floor-navigator/` de ton instance HAOS,
# accessible depuis ton poste de dev (typiquement via un partage Samba mappé en lecteur réseau).
# En mode `npm run watch`, Rollup écrira `floor-navigator.js` directement dans ce dossier
# pour que HA serve la version fraîche à chaque save (cf. SPEC.md section 6.2).
#
# Exemple sous Windows avec le partage Samba de HAOS mappé en `Z:` :
#   HA_LOCAL_DIR=Z:/www/floor-navigator
#
# Si la variable n'est pas définie, `npm run watch` retombe sur `dist/` comme `npm run build`.

HA_LOCAL_DIR=Z:/www/floor-navigator
